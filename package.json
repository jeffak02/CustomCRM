{
  "name": "geistwerks",
  "version": "1.3.8",
  "description": "GeistWerks CRM — Automotive Shop Management",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --dir",
    "dist": "electron-builder --mac",
    "release": "electron-builder --mac --publish always"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.geistwerks.crm",
    "productName": "GeistWerks",
    "files": [
      "main.js",
      "preload.js",
      "geistwerks.html",
      "AppIcon.icns",
      "css/**",
      "js/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "jeffak02",
      "repo": "CustomCRM"
    },
    "mac": {
      "icon": "AppIcon.icns",
      "category": "public.app-category.business",
      "target": [
        { "target": "pkg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    },
    "pkg": {
      "allowAnywhere": true,
      "allowCurrentUserHome": false,
      "isRelocatable": false
    }
  }
}
